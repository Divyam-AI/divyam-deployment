{
  "name": "kubernetes",
  "description": "Kubernetes alerts (deployment / pod / pvc / statefulset health).",
  "interval": "1m",
  "rules": [
    {
      "alert": "deployment-replica-mismatch",
      "expr": "(kube_deployment_status_replicas_available / kube_deployment_spec_replicas) < 0.8",
      "for": "2m",
      "severity": "CRITICAL",
      "auto_resolve": "30m",
      "labels": {
        "rule_group": "Kubernetes",
        "alert_rule": "AlwaysOn"
      },
      "annotations": {
        "summary": "Deployment Replica Mismatch",
        "description": "Less than 80% of replicas are available"
      },
      "datadog": {
        "query": "avg(last_5m):avg:kubernetes_state.deployment.replicas_available{*} by {kube_cluster_name,kube_namespace,kube_deployment} / avg:kubernetes_state.deployment.replicas_desired{*} by {kube_cluster_name,kube_namespace,kube_deployment} < 0.8",
        "message": "Deployment {{kube_deployment.name}} in namespace {{kube_namespace.name}} on cluster {{kube_cluster_name.name}} has less than 80% replicas available."
      }
    },
    {
      "alert": "pods-in-crashloopbackoff",
      "expr": "(kube_pod_container_status_waiting_reason{reason='CrashLoopBackOff'}) > 0",
      "for": "2m",
      "severity": "CRITICAL",
      "auto_resolve": "30m",
      "labels": {
        "rule_group": "Kubernetes",
        "alert_rule": "AlwaysOn"
      },
      "annotations": {
        "summary": "Pods in CrashLoopBackOff",
        "description": "One or more pods are in CrashLoopBackOff state"
      },
      "datadog": {
        "query": "avg(last_5m):sum:kubernetes_state.container.status_report.count.waiting{reason:crashloopbackoff} by {kube_cluster_name,kube_namespace,pod_name} > 0",
        "message": "Pod {{pod_name.name}} in namespace {{kube_namespace.name}} on cluster {{kube_cluster_name.name}} is in CrashLoopBackOff."
      }
    },
    {
      "alert": "pods-in-failed-state",
      "expr": "(kube_pod_status_phase{phase='Failed'}) > 0",
      "for": "2m",
      "severity": "CRITICAL",
      "auto_resolve": "30m",
      "labels": {
        "rule_group": "Kubernetes",
        "alert_rule": "AlwaysOn"
      },
      "annotations": {
        "summary": "Pods in Failed State",
        "description": "One or more pods are in Failed phase"
      },
      "datadog": {
        "query": "avg(last_5m):sum:kubernetes_state.pod.status_phase{phase:failed} by {kube_cluster_name,kube_namespace,pod_name} > 0",
        "message": "Pod {{pod_name.name}} in namespace {{kube_namespace.name}} on cluster {{kube_cluster_name.name}} is in Failed phase."
      }
    },
    {
      "alert": "pvc-unbound-state",
      "expr": "(kube_persistentvolumeclaim_status_phase{phase!='Bound'}) > 0",
      "for": "1m",
      "severity": "CRITICAL",
      "auto_resolve": "30m",
      "labels": {
        "rule_group": "Kubernetes",
        "alert_rule": "AlwaysOn"
      },
      "annotations": {
        "summary": "PVC Unbound State",
        "description": "One or more PVCs are not in Bound state"
      },
      "datadog": {
        "query": "avg(last_5m):sum:kubernetes_state.persistentvolumeclaim.status{phase:pending OR phase:lost} by {kube_cluster_name,kube_namespace,persistentvolumeclaim} > 0",
        "message": "PVC {{persistentvolumeclaim.name}} in namespace {{kube_namespace.name}} on cluster {{kube_cluster_name.name}} is not Bound."
      }
    },
    {
      "alert": "pvc-usage-high",
      "expr": "(kubelet_volume_stats_used_bytes * 100 / kubelet_volume_stats_capacity_bytes) > 60",
      "for": "1m",
      "severity": "WARNING",
      "auto_resolve": "30m",
      "labels": {
        "rule_group": "Kubernetes",
        "alert_rule": "AlwaysOn"
      },
      "annotations": {
        "summary": "PVC Usage High",
        "description": "PVC usage has exceeded 60%"
      },
      "datadog": {
        "query": "avg(last_5m):(avg:kubernetes.io.persistentvolumeclaim.used_bytes{*} by {kube_cluster_name,kube_namespace,persistentvolumeclaim} / avg:kubernetes.io.persistentvolumeclaim.capacity_bytes{*} by {kube_cluster_name,kube_namespace,persistentvolumeclaim}) * 100 > 60",
        "message": "PVC {{persistentvolumeclaim.name}} in namespace {{kube_namespace.name}} on cluster {{kube_cluster_name.name}} exceeded 60% usage."
      }
    },
    {
      "alert": "statefulset-replica-mismatch",
      "expr": "(kube_statefulset_status_replicas_ready / kube_statefulset_replicas) < 0.8",
      "for": "2m",
      "severity": "CRITICAL",
      "auto_resolve": "30m",
      "labels": {
        "rule_group": "Kubernetes",
        "alert_rule": "AlwaysOn"
      },
      "annotations": {
        "summary": "StatefulSet Replica Mismatch",
        "description": "Less than 80% of StatefulSet replicas are ready"
      },
      "datadog": {
        "query": "avg(last_5m):avg:kubernetes_state.statefulset.replicas_ready{*} by {kube_cluster_name,kube_namespace,kube_statefulset} / avg:kubernetes_state.statefulset.replicas_desired{*} by {kube_cluster_name,kube_namespace,kube_statefulset} < 0.8",
        "message": "StatefulSet {{kube_statefulset.name}} in namespace {{kube_namespace.name}} on cluster {{kube_cluster_name.name}} has less than 80% replicas ready."
      }
    }
  ]
}
