{
  "id": "e66-vxb-qei",
  "title": "Router Controller",
  "description": "Industry-standard monitoring dashboard for the Router Controller production deployment (router-controller-prod-deploy) in router-controller-prod-ns on divyam-prod-k8s-cluster. Tracks API key DB lookup latency, in-flight request concurrency, resource utilization, and pod health for early degradation detection.",
  "author_handle": "rbharathkumar0409@gmail.com",
  "author_name": "Bharath Kumar",
  "layout_type": "ordered",
  "url": "/dashboard/e66-vxb-qei/router-controller",
  "template_variables": [
    {
      "name": "kube_namespace",
      "prefix": "kube_namespace",
      "available_values": [
        "router-controller-prod-ns"
      ],
      "default": "router-controller-prod-ns"
    },
    {
      "name": "kube_deployment",
      "prefix": "kube_deployment",
      "available_values": [
        "router-controller-prod-deploy"
      ],
      "default": "router-controller-prod-deploy"
    },
    {
      "name": "kube_cluster_name",
      "prefix": "kube_cluster_name",
      "available_values": [
        "divyam-prod-k8s-cluster"
      ],
      "default": "divyam-prod-k8s-cluster"
    },
    {
      "name": "endpoint",
      "prefix": "endpoint",
      "available_values": [],
      "default": "*"
    }
  ],
  "widgets": [
    {
      "id": 7715741023444291,
      "definition": {
        "title": "Overview - Key Performance Indicators",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 7191917738459986,
            "definition": {
              "type": "note",
              "content": "**Router Controller Prod Monitoring**\n\nMonitoring API key lookup latency, in-flight concurrency, and infrastructure health for `router-controller-prod-deploy` in `router-controller-prod-ns`.\n\nUse this dashboard to detect API degradations, resource saturation, and pod instability early.",
              "background_color": "blue",
              "font_size": "14",
              "text_align": "left",
              "vertical_align": "top",
              "show_tick": false,
              "tick_pos": "50%",
              "tick_edge": "left",
              "has_padding": true
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 4,
              "height": 2
            }
          },
          {
            "id": 905552930411616,
            "definition": {
              "title": "In-Flight Requests",
              "type": "query_value",
              "requests": [
                {
                  "aggregator": "last",
                  "conditional_formats": [
                    {
                      "comparator": ">=",
                      "palette": "white_on_red",
                      "value": 50
                    },
                    {
                      "comparator": ">=",
                      "palette": "white_on_yellow",
                      "value": 20
                    },
                    {
                      "comparator": "<",
                      "palette": "white_on_green",
                      "value": 20
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "a"
                    }
                  ],
                  "queries": [
                    {
                      "aggregator": "last",
                      "data_source": "metrics",
                      "name": "a",
                      "query": "avg:router_controller_prod_ns.divyam_in_flight_requests{$kube_namespace,$kube_deployment,$endpoint}"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "autoscale": true,
              "precision": 1
            },
            "layout": {
              "x": 4,
              "y": 0,
              "width": 2,
              "height": 2
            }
