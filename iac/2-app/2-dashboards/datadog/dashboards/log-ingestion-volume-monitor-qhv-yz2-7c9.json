        "widgets": [
          {
            "id": 2461416869725280,
            "definition": {
              "type": "note",
              "content": "**Debug Log Detection**\n\nThis section monitors for debug-level log messages being ingested. Debug logs in production increase costs and add noise. Services flagged here should have their log levels reviewed.\n\nThe detection searches for messages containing `<Debug>` patterns and logs with `status:debug`. Review flagged services and adjust log levels accordingly.",
              "background_color": "yellow",
              "font_size": "14",
              "text_align": "left",
              "vertical_align": "top",
              "show_tick": false,
              "tick_pos": "50%",
              "tick_edge": "left",
