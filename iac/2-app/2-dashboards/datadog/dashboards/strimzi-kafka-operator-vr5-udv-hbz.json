{
  "id": "vr5-udv-hbz",
  "title": "Strimzi Kafka Operator",
  "description": "Comprehensive monitoring dashboard for the Strimzi Kafka Operator running in the kafka-prod-ns namespace on divyam-prod-k8s-cluster. Covers operator reconciliations, managed resources, JVM performance, garbage collection, and Vert.x HTTP server and thread pool metrics.",
  "author_handle": "rbharathkumar0409@gmail.com",
  "author_name": "Bharath Kumar",
  "layout_type": "ordered",
  "url": "/dashboard/vr5-udv-hbz/strimzi-kafka-operator",
  "template_variables": [
    {
      "name": "kube_cluster_name",
      "prefix": "kube_cluster_name",
      "available_values": [
        "divyam-prod-k8s-cluster"
      ],
      "default": "divyam-prod-k8s-cluster"
    },
    {
      "name": "kube_namespace",
      "prefix": "kube_namespace",
      "available_values": [
        "kafka-prod-ns"
      ],
      "default": "kafka-prod-ns"
    }
  ],
  "widgets": [
    {
      "id": 3238001059367434,
      "definition": {
        "title": "Operator Overview",
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 4621981262059923,
            "definition": {
              "type": "note",
              "content": "Monitoring the **Strimzi Kafka Operator** (`v0.45.0`) running on `divyam-prod-k8s-cluster` (AKS) in `kafka-prod-ns`.\n\nThis dashboard covers operator reconciliations, managed Kafka resources, JVM health (memory, GC, threads), and the embedded Vert.x HTTP server and worker pool.\n\n**Key signals to watch:**\n- Reconciliation rate spikes or drops\n- JVM heap usage approaching max\n- GC pause frequency and duration\n- Vert.x request latency and queue depth",
              "background_color": "white",
              "font_size": "14",
              "text_align": "left",
              "vertical_align": "top",
              "show_tick": false,
              "tick_pos": "50%",
              "tick_edge": "left",
              "has_padding": true
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 3,
              "height": 4
            }
          },
          {
            "id": 6088694345236299,
