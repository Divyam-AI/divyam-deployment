{
  "uid": "divyam-otel",
  "title": "Divyam \u00b7 OTel Collector",
  "tags": [
    "divyam",
    "otel"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "timezone": "",
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "About",
      "type": "text",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "OpenTelemetry Collector self-metrics (`otelcol_*`). If empty, confirm the collector's Prometheus telemetry endpoint is scraped by a PodMonitor. Metric suffixes vary by signal (`_spans` / `_metric_points` / `_log_records`)."
      }
    },
    {
      "id": 2,
      "title": "Exporter queue size vs capacity",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (exporter) (otelcol_exporter_queue_size)",
          "legendFormat": "size {{exporter}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (exporter) (otelcol_exporter_queue_capacity)",
          "legendFormat": "capacity {{exporter}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": ""
    },
    {
      "id": 3,
      "title": "Exporter send failures (rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (exporter) (rate(otelcol_exporter_send_failed_spans[5m]))",
          "legendFormat": "spans {{exporter}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (exporter) (rate(otelcol_exporter_send_failed_metric_points[5m]))",
          "legendFormat": "metrics {{exporter}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (exporter) (rate(otelcol_exporter_send_failed_log_records[5m]))",
          "legendFormat": "logs {{exporter}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": ""
    },
    {
      "id": 4,
      "title": "Receiver accepted vs refused (rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum (rate(otelcol_receiver_accepted_spans[5m]))",
          "legendFormat": "accepted spans",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum (rate(otelcol_receiver_refused_spans[5m]))",
          "legendFormat": "refused spans",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum (rate(otelcol_receiver_accepted_metric_points[5m]))",
          "legendFormat": "accepted metrics",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": ""
    },
    {
      "id": 5,
      "title": "Exporter sent (rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 12,
        "y": 11,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (exporter) (rate(otelcol_exporter_sent_spans[5m]))",
          "legendFormat": "spans {{exporter}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (exporter) (rate(otelcol_exporter_sent_metric_points[5m]))",
          "legendFormat": "metrics {{exporter}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": ""
    },
    {
      "id": 6,
      "title": "Collector up",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "up{job=~\".*otel.*\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "description": ""
    }
  ],
  "annotations": {
    "list": []
  }
}