{
  "uid": "divyam-kafka",
  "title": "Divyam \u00b7 Kafka",
  "tags": [
    "divyam",
    "kafka"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "timezone": "",
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {}
      },
      {
        "type": "query",
        "name": "namespace",
        "label": "Namespace",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(kafka_consumergroup_lag, namespace)",
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": {},
        "hide": 0
      },
      {
        "type": "query",
        "name": "topic",
        "label": "Topic",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(kafka_consumergroup_lag{namespace=~\"$namespace\"}, topic)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Consumer group lag (max by group/topic)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (consumergroup, topic) (kafka_consumergroup_lag{namespace=~\"$namespace\",topic=~\"$topic\"})",
          "legendFormat": "{{consumergroup}}/{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": "Verified metric from kafka.json alert rules."
    },
    {
      "id": 2,
      "title": "Lag growth rate (deriv, 10m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (consumergroup, topic) (deriv(kafka_consumergroup_lag{namespace=~\"$namespace\",topic=~\"$topic\"}[10m]))",
          "legendFormat": "{{consumergroup}}/{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": ""
    },
    {
      "id": 3,
      "title": "Under-replicated partitions",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 12,
        "y": 9,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (namespace) (kafka_topic_partition_under_replicated_partition{namespace=~\"$namespace\"})",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": "Write-failure / broker-health signal."
    },
    {
      "id": 4,
      "title": "Broker disk usage %",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max by (persistentvolumeclaim) (kubelet_volume_stats_used_bytes{namespace=~\"$namespace\"} / kubelet_volume_stats_capacity_bytes{namespace=~\"$namespace\"} * 100)",
          "legendFormat": "{{persistentvolumeclaim}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": ""
    },
    {
      "id": 5,
      "title": "Topic throughput (offset rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 12,
        "y": 17,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": "\u26a0 kafka_topic_partition_current_offset from kafka-exporter \u2014 verify it's scraped."
    }
  ],
  "annotations": {
    "list": []
  }
}