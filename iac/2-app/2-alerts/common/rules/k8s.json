{
  "name": "kubernetes",
  "description": "Kubernetes alerts (deployment / pod / pvc / statefulset health).",
  "interval": "1m",
  "labels": {
    "rule_group": "Kubernetes",
    "alert_rule": "AlwaysOn"
  },
  "rules": [
    {
      "alert": "deployment-replica-mismatch",
      "query": {
        "terms": [{ "metric": "replicas_available" }],
        "denominator": [{ "metric": "replicas_desired" }],
        "comparison": "<",
        "aggregation": "avg",
        "group_by": ["kube_namespace", "kube_deployment"],
        "rollup": "min"
      },
      "window": "15m",
      "for": "2m",
      "severity": "CRITICAL",
      "auto_resolve": "30m",
      "thresholds": {
        "critical": "0.8",
        "warning": "0.9",
        "critical_recovery": "0.85",
        "warning_recovery": "0.95"
      },
      "annotations": {
        "summary": "Deployment Replica Mismatch",
        "description": "Warn when < 90% replicas available; critical when < 80%; recover above 85% (crit) / 95% (warn)",
        "runbook_url": "https://runbooks.divyam.ai/kubernetes/deployment-replica-mismatch"
      },
      "datadog": {
        "message": "Deployment {{kube_deployment.name}} in namespace {{kube_namespace.name}} on cluster {{kube_cluster_name.name}} has less than 80% replicas available."
      }
    },
    {
      "alert": "pods-in-crashloopbackoff",
      "query": {
        "terms": [{ "metric": "container_waiting", "filters": { "reason": "CrashLoopBackOff" } }],
        "comparison": ">",
        "aggregation": "sum",
        "group_by": ["kube_namespace", "pod_name"],
        "rollup": "max"
      },
      "window": "15m",
      "for": "2m",
      "severity": "CRITICAL",
      "auto_resolve": "30m",
      "thresholds": { "critical": "0" },
      "annotations": {
        "summary": "Pods in CrashLoopBackOff",
        "description": "One or more pods are in CrashLoopBackOff state",
        "runbook_url": "https://runbooks.divyam.ai/kubernetes/pods-in-crashloopbackoff"
      },
      "datadog": {
        "message": "Pod {{pod_name.name}} in namespace {{kube_namespace.name}} on cluster {{kube_cluster_name.name}} is in CrashLoopBackOff."
      }
    },
    {
      "alert": "pods-in-failed-state",
      "query": {
        "terms": [{ "metric": "pod_phase", "filters": { "phase": "Failed" } }],
        "comparison": ">",
        "aggregation": "sum",
        "group_by": ["kube_namespace", "pod_name"],
        "rollup": "max"
      },
      "window": "15m",
      "for": "2m",
      "severity": "CRITICAL",
      "auto_resolve": "30m",
      "thresholds": { "critical": "0" },
      "annotations": {
        "summary": "Pods in Failed State",
        "description": "One or more pods are in Failed phase",
        "runbook_url": "https://runbooks.divyam.ai/kubernetes/pods-in-failed-state"
      },
      "datadog": {
        "message": "Pod {{pod_name.name}} in namespace {{kube_namespace.name}} on cluster {{kube_cluster_name.name}} is in Failed phase."
      }
    },
    {
      "alert": "pvc-unbound-state",
      "_comment": "Template rule (hybrid escape hatch): PromQL uses phase!='Bound' (negation), Datadog sums the pending + lost series. These shapes diverge per backend, so the query is authored per backend with placeholders rather than via the structured `query` IR.",
      "expr": "(kube_persistentvolumeclaim_status_phase{phase!='Bound'}) > {{threshold}}",
      "window": "15m",
      "for": "1m",
      "severity": "CRITICAL",
      "auto_resolve": "30m",
      "thresholds": { "critical": "0" },
      "annotations": {
        "summary": "PVC Unbound State",
        "description": "One or more PVCs are not in Bound state",
        "runbook_url": "https://runbooks.divyam.ai/kubernetes/pvc-unbound-state"
      },
      "datadog": {
        "query": "max(last_{{window}}):sum:kubernetes_state.persistentvolumeclaim.status{phase:pending,kube_cluster_name:{{cluster_name}}} by {kube_namespace,persistentvolumeclaim} + sum:kubernetes_state.persistentvolumeclaim.status{phase:lost,kube_cluster_name:{{cluster_name}}} by {kube_namespace,persistentvolumeclaim} > {{threshold}}",
        "message": "PVC {{persistentvolumeclaim.name}} in namespace {{kube_namespace.name}} on cluster {{kube_cluster_name.name}} is not Bound."
      }
    },
    {
      "alert": "pvc-usage-high",
      "query": {
        "terms": [{ "metric": "pvc_used_bytes" }],
        "denominator": [{ "metric": "pvc_capacity_bytes" }],
        "comparison": ">",
        "scale": 100,
        "aggregation": "avg",
        "group_by": ["kube_namespace", "persistentvolumeclaim"],
        "rollup": "min"
      },
      "window": "15m",
      "for": "1m",
      "severity": "WARNING",
      "auto_resolve": "30m",
      "thresholds": { "critical": "60" },
      "annotations": {
        "summary": "PVC Usage High",
        "description": "PVC usage has exceeded warning (60%) or critical (80%) thresholds",
        "runbook_url": "https://runbooks.divyam.ai/kubernetes/pvc-usage-high"
      },
      "datadog": {
        "notify": true,
        "thresholds": {
          "warning": "60",
          "critical": "80",
          "warning_recovery": "55",
          "critical_recovery": "75"
        },
        "message": "PVC {{persistentvolumeclaim.name}} in namespace {{kube_namespace.name}} on cluster {{kube_cluster_name.name}} exceeded usage thresholds (warn 60%, critical 80%)."
      }
    },
    {
      "alert": "statefulset-replica-mismatch",
      "query": {
        "terms": [{ "metric": "sts_replicas_ready" }],
        "denominator": [{ "metric": "sts_replicas_desired" }],
        "comparison": "<",
        "aggregation": "avg",
        "group_by": ["kube_namespace", "kube_statefulset"],
        "rollup": "min"
      },
      "window": "15m",
      "for": "2m",
      "severity": "CRITICAL",
      "auto_resolve": "30m",
      "thresholds": {
        "critical": "0.8",
        "warning": "0.9",
        "critical_recovery": "0.85",
        "warning_recovery": "0.95"
      },
      "annotations": {
        "summary": "StatefulSet Replica Mismatch",
        "description": "Warn when < 90% replicas ready; critical when < 80%; recover above 85% (crit) / 95% (warn)",
        "runbook_url": "https://runbooks.divyam.ai/kubernetes/statefulset-replica-mismatch"
      },
      "datadog": {
        "message": "StatefulSet {{kube_statefulset.name}} in namespace {{kube_namespace.name}} on cluster {{kube_cluster_name.name}} has less than 80% replicas ready."
      }
    }
  ]
}
