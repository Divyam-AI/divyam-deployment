**/.terraform
**/*.tfstate
**/*.tfstate.backup
**/.terragrunt-cache/
**/.terraform-version
**/.terraform.lock.hcl
**/.terraformrc
**/.terraform.d
**/.terraformrc
**/.terraform/
**/.terraform.d/
**/.terraform-version
**/.terraform.lock.hcl
**/.DS_Store
**/secrets-*.txt

**/pycache__
**/__pycache__

dev-artifacts.yaml

# Terragrunt/Terraform outputs written for Helm (generated by scripts/write-outputs-yaml.sh)
outputs/*
**/deployment/charts/*/tmp
**/*-dev-template.yaml
**/*-preprod-template.yaml
**/*-prod-template.yaml
**/generated_helm_charts.yaml
# ignore dependency helm charts
**/charts/*.tgz

# ignore intellij project files
.idea/
# generated throwaway TF secrets (gen-tf-env.sh) — never commit
.tf-secrets.env
*.tf-secrets.env

# iac.sh remembered cloud/env + prevent_destroy backups
.iac.conf
# bringup.sh per-(cloud,env) step ledger — query via `make bringup -- status`, never read directly
.bringup-status.*
*.pdbak

# generated Terraform config+secrets (auto-sourced by iac.sh) and k8s.sh remembered config
iac/values/secrets.env
iac/values/secrets.env.*
.k8s.conf

# temporary config-driven import files (scripts/reconcile) — deleted after apply, never committed
**/zz_import_*.tf

# Per-environment EFFECTIVE Helm values (copy of sample-resources.yaml / sample-config.yaml, tuned
# per deployment; provider.yaml is generated by 2-app). Commit the sample-*.yaml, not these.
k8s/helm-values/resources.yaml
